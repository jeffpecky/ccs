{
  "name": "@jeffpecky/ccs",
  "version": "8.3.0",
  "description": "CCS Dashboard - Management dashboard for CLIProxyAPI",
  "keywords": [
    "dashboard",
    "cliproxy",
    "ai",
    "proxy",
    "management"
  ],
  "homepage": "https://github.com/jeffpecky/ccs",
  "bugs": {
    "url": "https://github.com/jeffpecky/ccs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffpecky/ccs.git"
  },
  "license": "MIT",
  "author": {
    "name": "Tam Nhu Tran (Kai)",
    "email": "kaitranntt@users.noreply.github.com"
  },
  "files": [
    "dist/",
    ".claude/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.9",
  "main": "dist/ccs.js",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "build:watch": "tsc --watch",
    "build:all": "bun run ui:build && bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "ui:build": "cd ui && bun run build",
    "ui:dev": "cd ui && bun run dev",
    "ui:preview": "cd ui && bun run preview",
    "ui:validate": "cd ui && bun run validate",
    "start": "node dist/ccs.js",
    "dev": "bun run build && node dist/ccs.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "chokidar": "^3.6.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "get-port": "^5.1.1",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "js-yaml": "^4.1.1",
    "mime": "1.6.0",
    "proper-lockfile": "^4.1.2",
    "smol-toml": "^1.6.1",
    "undici": "^5.29.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "^1.3.12",
    "@types/chokidar": "^2.1.7",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "6.0.0",
    "@types/express-session": "^1.18.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.25",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-react": "^5.1.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "listr2": "^3.14.0",
    "marked": "^15.0.12",
    "mocha": "^11.7.5",
    "ora": "^5.4.1",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.2",
    "typescript": "5.3",
    "vite": "^7.2.4"
  }
}
